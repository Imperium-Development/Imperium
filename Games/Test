local ADMINS = {
    5127756688
}

local MODS = {
    000
}

local PREMIUMS = {
    000
}

local playersUsingScript = {}

-- Crear o acceder al espacio compartido en Workspace
local scriptUsersFolder = workspace:FindFirstChild("ScriptUsersFolder")
if not scriptUsersFolder then
    scriptUsersFolder = Instance.new("Folder")
    scriptUsersFolder.Name = "ScriptUsersFolder"
    scriptUsersFolder.Parent = workspace
end

local function formatNumber(n)
    n = tostring(n)
    return n:reverse():gsub("%d%d%d", "%1,"):reverse():gsub("^,", "")
end

-- Función para registrar al jugador en el espacio compartido
local function registerPlayerInFolder(player)
    local userValue = scriptUsersFolder:FindFirstChild(tostring(player.UserId))
    if not userValue then
        local newValue = Instance.new("StringValue")
        newValue.Name = tostring(player.UserId)
        newValue.Value = player.Name
        newValue.Parent = scriptUsersFolder
    end
end

local function updateDisplayName(player)
    local humanoid = player.Character and player.Character:FindFirstChildWhichIsA('Humanoid')
    if humanoid then
        local plrID = player.UserId
        if table.find(ADMINS, plrID) then
            humanoid.DisplayName = ('[\240\159\166\135] ' .. player.DisplayName) -- 🦇
        elseif table.find(MODS, plrID) then
            humanoid.DisplayName = ('[\240\159\145\137] ' .. player.DisplayName) -- 👑
        elseif table.find(PREMIUMS, plrID) then
            humanoid.DisplayName = ('[\226\173\144] ' .. player.DisplayName)     -- ⭐
        elseif table.find(playersUsingScript, plrID) then
            humanoid.DisplayName = ('[\240\159\152\142] ' .. player.DisplayName) -- 😎
        end
    end
end

-- Función para detectar a otros jugadores usando el script
local function detectOtherScriptUsers()
    for _, userValue in pairs(scriptUsersFolder:GetChildren()) do
        local userId = tonumber(userValue.Name)
        if userId and not table.find(playersUsingScript, userId) then
            table.insert(playersUsingScript, userId)
            local plr = game.Players:GetPlayerByUserId(userId)
            if plr and plr.Character then
                local humanoid = plr.Character:FindFirstChildWhichIsA("Humanoid")
                if humanoid then
                    humanoid.DisplayName = ('[\240\159\152\142] ' .. plr.DisplayName) -- 😎 Emoji
                end
            end
        end
    end
end

-- Función al agregar un personaje
local function onCharacterAdded(player)
    player.CharacterAdded:Connect(function(character)
        local humanoid = character:WaitForChild('Humanoid')
        registerPlayerInFolder(player)
        updateDisplayName(player)
        detectOtherScriptUsers()
    end)
end

local function ImperiumEmojis()
    for _, player in pairs(game.Players:GetPlayers()) do
        onCharacterAdded(player)
        registerPlayerInFolder(player)
        updateDisplayName(player)
    end
end

-- Inicializa el script para el jugador local
local localPlayer = game.Players.LocalPlayer
registerPlayerInFolder(localPlayer)
updateDisplayName(localPlayer)

localPlayer.CharacterAdded:Connect(function()
    updateDisplayName(localPlayer)
    detectOtherScriptUsers()
end)

-- Detectar otros jugadores usando el script en tiempo real
scriptUsersFolder.ChildAdded:Connect(detectOtherScriptUsers)
scriptUsersFolder.ChildRemoved:Connect(detectOtherScriptUsers)

game.Players.PlayerAdded:Connect(function(player)
    onCharacterAdded(player)
end)

-- Mantener actualizados los nombres periódicamente
while true do
    detectOtherScriptUsers()
    wait(2) -- Comprobación cada 2 segundos
end

local succ, errr = pcall(ImperiumEmojis)
if not succ then
    warn("> Imperium  |  Error  •  While executing Name Emojis: " .. errr)
end
