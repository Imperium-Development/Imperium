local ADMINS = {
    5127756688 -- Ejemplo de ID de Admin
}
local MODS = {}
local PREMIUMS = {}

local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local LocalPlayer = Players.LocalPlayer

-- Crear un bloque compartido para "usuarios del script"
local scriptUsersFolder = Workspace:FindFirstChild("ScriptUsers") or Instance.new("Folder")
scriptUsersFolder.Name = "ScriptUsers"
scriptUsersFolder.Parent = Workspace

-- Registrar al jugador local en ScriptUsersFolder
local function markPlayer()
    local marker = scriptUsersFolder:FindFirstChild(tostring(LocalPlayer.UserId))
    if not marker then
        local userValue = Instance.new("StringValue")
        userValue.Name = tostring(LocalPlayer.UserId)
        userValue.Value = LocalPlayer.Name
        userValue.Parent = scriptUsersFolder
    end
end

-- Función para actualizar nombres según rango o script
local function updateDisplayNames()
    for _, player in ipairs(Players:GetPlayers()) do
        if player.Character and player.Character:FindFirstChildWhichIsA("Humanoid") then
            local humanoid = player.Character:FindFirstChildWhichIsA("Humanoid")
            local userId = player.UserId

            -- Prioridad de rangos
            if table.find(ADMINS, userId) then
                humanoid.DisplayName = "[💎] " .. player.DisplayName
            elseif table.find(MODS, userId) then
                humanoid.DisplayName = "[👑] " .. player.DisplayName
            elseif table.find(PREMIUMS, userId) then
                humanoid.DisplayName = "[⭐] " .. player.DisplayName
            elseif scriptUsersFolder:FindFirstChild(tostring(userId)) then
                humanoid.DisplayName = "[😎] " .. player.DisplayName
            end
        end
    end
end

-- Evento para actualizar nombres cuando un personaje se añade
local function onCharacterAdded(character)
    wait(1) -- Pequeña espera para asegurar que todo carga
    updateDisplayNames()
end

-- Inicialización
markPlayer()
updateDisplayNames()

-- Conectar eventos
Players.PlayerAdded:Connect(function(player)
    player.CharacterAdded:Connect(onCharacterAdded)
end)

LocalPlayer.CharacterAdded:Connect(onCharacterAdded)

-- Actualización periódica
while true do
    updateDisplayNames()
    wait(2)
end
