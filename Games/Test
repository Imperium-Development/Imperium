local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

-- Crear un RemoteEvent para la comunicación cliente-servidor
local remote = Instance.new("RemoteEvent")
remote.Name = "MarkPlayerUsingScript"
remote.Parent = ReplicatedStorage

-- Listas de roles
local ADMINS = {5127756688} -- IDs de administradores
local MODS = {} -- IDs de moderadores
local PREMIUMS = {} -- IDs de premium

-- Lista centralizada de jugadores que usan el script
local playersUsingScript = {}

-- Función para formatear el nombre del jugador
local function updateDisplayName(player)
    local humanoid = player.Character and player.Character:FindFirstChildWhichIsA("Humanoid")
    if humanoid then
        local plrID = player.UserId
        local displayName = player.DisplayName

        -- Cambiar el DisplayName según el rol
        if table.find(ADMINS, plrID) then
            humanoid.DisplayName = ('[\240\159\166\135] ' .. displayName) -- 🦇
        elseif table.find(MODS, plrID) then
            humanoid.DisplayName = ('[\240\159\145\137] ' .. displayName) -- 👑
        elseif table.find(PREMIUMS, plrID) then
            humanoid.DisplayName = ('[\226\173\144] ' .. displayName) -- ⭐
        elseif table.find(playersUsingScript, plrID) then
            humanoid.DisplayName = ('[\240\159\152\142] ' .. displayName) -- 😎
        end
    end
end

-- Registrar jugadores que usan el script
remote.OnServerEvent:Connect(function(player)
    if not table.find(playersUsingScript, player.UserId) then
        table.insert(playersUsingScript, player.UserId)
    end
end)

-- Manejar cuando un jugador o su personaje es añadido
local function onPlayerAdded(player)
    player.CharacterAdded:Connect(function()
        updateDisplayName(player)
    end)
end

-- Manejar todos los jugadores actuales y futuros
Players.PlayerAdded:Connect(onPlayerAdded)
for _, player in pairs(Players:GetPlayers()) do
    onPlayerAdded(player)
end

-- Notificar al servidor cuando el jugador está usando el script
local function onScriptExecuted(player)
    remote:FireServer(player)
end

-- Ejecutar la función para todos los jugadores locales al añadir el script
for _, player in pairs(Players:GetPlayers()) do
    onScriptExecuted(player)
end
