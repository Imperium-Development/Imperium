local ADMINS = {
    5127756688
}

local MODS = {
    000
}

local PREMIUMS = {
    000
}

local playersUsingScript = {}

local function formatNumber(n)
    n = tostring(n)
    return n:reverse():gsub("%d%d%d", "%1,"):reverse():gsub("^,", "")
end

-- Marcar jugadores que usan el script
local function markPlayerUsingScript(playerId)
    if not table.find(playersUsingScript, playerId) then
        table.insert(playersUsingScript, playerId)
    end
end

-- Actualizar el DisplayName según el rol
local function updateDisplayName(player)
    local humanoid = player.Character and player.Character:FindFirstChildWhichIsA('Humanoid')
    if humanoid then
        local plrID = player.UserId
        if table.find(ADMINS, plrID) then
            humanoid.DisplayName = ('[\240\159\166\135] ' .. player.DisplayName) -- 🦇
        elseif table.find(MODS, plrID) then
            humanoid.DisplayName = ('[\240\159\145\137] ' .. player.DisplayName) -- 👑
        elseif table.find(PREMIUMS, plrID) then
            humanoid.DisplayName = ('[\226\173\144] ' .. player.DisplayName) -- ⭐
        elseif table.find(playersUsingScript, plrID) then
            humanoid.DisplayName = ('[\240\159\152\142] ' .. player.DisplayName) -- 😎
        end
    end
end

-- Verificar y actualizar todos los jugadores en Workspace.Players
local function checkSwag()
    for _, playerModel in pairs(game:GetService('Workspace').Players:GetChildren()) do
        if playerModel:FindFirstChild('UpperTorso') then
            local humanoid = playerModel:FindFirstChildWhichIsA('Humanoid')
            local plrCheck = game:GetService('Players'):FindFirstChild(playerModel.Name)
            if plrCheck and humanoid then
                local plrID = plrCheck.UserId

                if table.find(ADMINS, plrID) then
                    humanoid.DisplayName = ('[\240\159\166\135] ' .. plrCheck.DisplayName) -- 🦇
                elseif table.find(MODS, plrID) then
                    humanoid.DisplayName = ('[\240\159\145\137] ' .. plrCheck.DisplayName) -- 👑
                elseif table.find(PREMIUMS, plrID) then
                    humanoid.DisplayName = ('[\226\173\144] ' .. plrCheck.DisplayName) -- ⭐
                elseif not table.find(playersUsingScript, plrID) then
                    markPlayerUsingScript(plrID)
                    humanoid.DisplayName = ('[\240\159\152\142] ' .. plrCheck.DisplayName) -- 😎
                end
            end
        end
    end
end

-- Detectar cuando un jugador añade su personaje
local function onCharacterAdded(player)
    player.CharacterAdded:Connect(function()
        updateDisplayName(player)
    end)
end

-- Inicializar el script
local function ImperiumEmojis()
    for _, player in pairs(game.Players:GetPlayers()) do
        onCharacterAdded(player)
        updateDisplayName(player)
    end
    checkSwag() -- Sincronizar con Workspace.Players
end

-- Marcar al jugador local como usuario del script
local localPlayer = game.Players.LocalPlayer
markPlayerUsingScript(localPlayer.UserId)

-- Actualizar el DisplayName del jugador local si cambia de personaje
localPlayer.CharacterAdded:Connect(function()
    updateDisplayName(localPlayer)
end)

-- Detectar nuevos jugadores y actualizarlos
game.Players.PlayerAdded:Connect(function(player)
    onCharacterAdded(player)
end)

-- Ejecutar y manejar errores
local success, errorMessage = pcall(ImperiumEmojis)
if not success then
    warn("> Imperium  |  Error  •  While executing Name Emojis: " .. errorMessage)
end
