local ADMINS = {
    5127756688  -- ID de administradores
}

local MODS = {
    000  -- ID de moderadores
}

local PREMIUMS = {
    000  -- ID de premium
}

local playersUsingScript = {}

local function formatNumber(n)
    n = tostring(n)
    return n:reverse():gsub("%d%d%d", "%1,"):reverse():gsub("^,", "")
end

local function markPlayerUsingScript(playerId)
    if not table.find(playersUsingScript, playerId) then
        table.insert(playersUsingScript, playerId)
    end
end

local function updateDisplayName(player)
    local humanoid = player.Character and player.Character:FindFirstChildWhichIsA('Humanoid')
    if humanoid then
        local plrID = player.UserId
        if table.find(ADMINS, plrID) then
            humanoid.DisplayName = ('[\240\159\166\135] ' .. player.DisplayName) -- 🦇 (Administrador)
        elseif table.find(MODS, plrID) then
            humanoid.DisplayName = ('[\240\159\145\137] ' .. player.DisplayName) -- 👑 (Moderador)
        elseif table.find(PREMIUMS, plrID) then
            humanoid.DisplayName = ('[\226\173\144] ' .. player.DisplayName)     -- ⭐ (Premium)
        elseif table.find(playersUsingScript, plrID) then
            humanoid.DisplayName = ('[\240\159\152\142] ' .. player.DisplayName) -- 😎 (Usando script)
        end
    end
end

local function onCharacterAdded(player)
    player.CharacterAdded:Connect(function(character)
        local humanoid = character:WaitForChild('Humanoid')
        updateDisplayName(player)
    end)
end

local localPlayer = game.Players.LocalPlayer
markPlayerUsingScript(localPlayer.UserId)

localPlayer.CharacterAdded:Connect(function()
    updateDisplayName(localPlayer)
end)

game.Players.PlayerAdded:Connect(function(player)
    if player:HasAppearanceLoaded() then
        -- Marca al jugador que está usando el script
        markPlayerUsingScript(player.UserId)
        updateDisplayName(player)
    end
    player.CharacterAdded:Connect(function(character)
        updateDisplayName(player)
    end)
end)

-- Ejecuta al inicio para los jugadores ya presentes
for _, player in ipairs(game.Players:GetPlayers()) do
    if player:HasAppearanceLoaded() then
        markPlayerUsingScript(player.UserId)
        updateDisplayName(player)
    end
end
