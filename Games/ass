-- [ BLACK HOLE FUCTION'S ] ---

local radius = 10
local angleSpeed = 2
local blackHoleActive = false

local ringActive = false
local ringCount = 8 
local ringRadius = 10 
local Attachments = {}

local function setupPlayer()
    local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local humanoidRootPart = character:WaitForChild("HumanoidRootPart")

    -- Órbita simple
    local Folder = Instance.new("Folder", Workspace)
    local Part = Instance.new("Part", Folder)
    local AttachmentSingle = Instance.new("Attachment", Part)
    Part.Anchored = true
    Part.CanCollide = false
    Part.Transparency = 1

    -- Órbitas múltiples
    local AttachmentList = {}
    for i = 1, ringCount do
        local Part = Instance.new("Part", Folder)
        local Attachment = Instance.new("Attachment", Part)
        Part.Anchored = true
        Part.CanCollide = false
        Part.Transparency = 1
        table.insert(AttachmentList, Attachment)
    end

    return humanoidRootPart, AttachmentSingle, AttachmentList
end

local humanoidRootPart, AttachmentSingle, Attachments = setupPlayer()

if not getgenv().Network then
    getgenv().Network = {
        BaseParts = {},
        Velocity = Vector3.new(14.46262424, 14.46262424, 14.46262424)
    }

    Network.RetainPart = function(part)
        if typeof(part) == "Instance" and part:IsA("BasePart") and part:IsDescendantOf(Workspace) then
            table.insert(Network.BaseParts, part)
            part.CustomPhysicalProperties = PhysicalProperties.new(0, 0, 0, 0, 0)
            part.CanCollide = false
        end
    end

    local function EnablePartControl()
        LocalPlayer.ReplicationFocus = Workspace
        RunService.Heartbeat:Connect(function()
            sethiddenproperty(LocalPlayer, "SimulationRadius", math.huge)
            for _, part in pairs(Network.BaseParts) do
                if part:IsDescendantOf(Workspace) then
                    part.Velocity = Network.Velocity
                end
            end
        end)
    end

    EnablePartControl()
end

local function ForcePart(v, attachment)
    if v:IsA("Part") and not v.Anchored and not v.Parent:FindFirstChild("Humanoid") and not v.Parent:FindFirstChild("Head") and v.Name ~= "Handle" then
        for _, x in next, v:GetChildren() do
            if x:IsA("BodyAngularVelocity") or x:IsA("BodyForce") or x:IsA("BodyGyro") or x:IsA("BodyPosition") or x:IsA("BodyThrust") or x:IsA("BodyVelocity") or x:IsA("RocketPropulsion") then
                x:Destroy()
            end
        end
        v.CanCollide = false

        local Torque = Instance.new("Torque", v)
        Torque.Torque = Vector3.new(1000000, 1000000, 1000000)
        local AlignPosition = Instance.new("AlignPosition", v)
        local Attachment2 = Instance.new("Attachment", v)
        Torque.Attachment0 = Attachment2
        AlignPosition.MaxForce = math.huge
        AlignPosition.MaxVelocity = math.huge
        AlignPosition.Responsiveness = 500
        AlignPosition.Attachment0 = Attachment2
        AlignPosition.Attachment1 = attachment
    end
end

local function toggleSingleBlackHole()
    if blackHoleActive then
        for _, v in next, Workspace:GetDescendants() do
            ForcePart(v, AttachmentSingle)
        end

        Workspace.DescendantAdded:Connect(function(v)
            if blackHoleActive then
                ForcePart(v, AttachmentSingle)
            end
        end)

        spawn(function()
            local angle = 1
            while blackHoleActive and RunService.RenderStepped:Wait() do
                angle = angle + math.rad(angleSpeed)
                local offsetX = math.cos(angle) * radius
                local offsetZ = math.sin(angle) * radius
                AttachmentSingle.WorldCFrame = humanoidRootPart.CFrame * CFrame.new(offsetX, 0, offsetZ)
            end
        end)
    else
        AttachmentSingle.WorldCFrame = CFrame.new(0, -1000, 0)
    end
end

local function toggleRingsBlackHole()
    if ringActive then
        for _, v in next, Workspace:GetDescendants() do
            for _, attachment in ipairs(Attachments) do
                ForcePart(v, attachment)
            end
        end

        Workspace.DescendantAdded:Connect(function(v)
            if ringActive then
                for _, attachment in ipairs(Attachments) do
                    ForcePart(v, attachment)
                end
            end
        end)

        spawn(function()
            local angle = 1
            while ringActive and RunService.RenderStepped:Wait() do
                angle = angle + math.rad(angleSpeed)
                for i, attachment in ipairs(Attachments) do
                    local offsetX = math.cos(angle + (math.pi * 2 / ringCount) * (i - 1)) * radius
                    local offsetZ = math.sin(angle + (math.pi * 2 / ringCount) * (i - 1)) * radius
                    local offsetY = (i - 1) * ringRadius
                    attachment.WorldCFrame = humanoidRootPart.CFrame * CFrame.new(offsetX, offsetY, offsetZ)
                end
            end
        end)
    else
        for _, attachment in ipairs(Attachments) do
            attachment.WorldCFrame = CFrame.new(0, -1000, 0)
        end
    end
end

LocalPlayer.CharacterAdded:Connect(function()
    humanoidRootPart, AttachmentSingle, Attachments = setupPlayer()
    if blackHoleActive then
        toggleSingleBlackHole()
    end
    if ringActive then
        toggleRingsBlackHole()
    end
end)

