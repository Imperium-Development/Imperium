local ADMINS = {
    5127756688 -- ID del Admin
}

local MODS = {
    -- IDs de Mods
}

local PREMIUMS = {
    -- IDs de Premiums
}

local localPlayer = game.Players.LocalPlayer
local playersUsingScript = {} -- Tabla para registrar jugadores usando el script

-- Crear o acceder al espacio compartido en Workspace
local scriptUsersFolder = workspace:FindFirstChild("ScriptUsersFolder")
if not scriptUsersFolder then
    scriptUsersFolder = Instance.new("Folder")
    scriptUsersFolder.Name = "ScriptUsersFolder"
    scriptUsersFolder.Parent = workspace
end

-- Función para registrar al jugador local en el Folder
local function registerLocalPlayer()
    if not scriptUsersFolder:FindFirstChild(tostring(localPlayer.UserId)) then
        local newValue = Instance.new("StringValue")
        newValue.Name = tostring(localPlayer.UserId)
        newValue.Value = localPlayer.Name
        newValue.Parent = scriptUsersFolder
    end
end

-- Función para actualizar el DisplayName respetando rangos
local function updateDisplayName(player)
    local humanoid = player.Character and player.Character:FindFirstChildWhichIsA('Humanoid')
    if humanoid then
        local userId = player.UserId
        if table.find(ADMINS, userId) then
            humanoid.DisplayName = ('[\240\159\166\135] ' .. player.DisplayName) -- 🦇 Admin
        elseif table.find(MODS, userId) then
            humanoid.DisplayName = ('[\240\159\145\137] ' .. player.DisplayName) -- 👑 Mod
        elseif table.find(PREMIUMS, userId) then
            humanoid.DisplayName = ('[\226\173\144] ' .. player.DisplayName)     -- ⭐ Premium
        elseif table.find(playersUsingScript, userId) then
            humanoid.DisplayName = ('[\240\159\152\142] ' .. player.DisplayName) -- 😎 Script User
        end
    end
end

-- Función para detectar otros jugadores usando el script
local function detectScriptUsers()
    playersUsingScript = {} -- Limpiar la lista
    for _, userValue in pairs(scriptUsersFolder:GetChildren()) do
        local userId = tonumber(userValue.Name)
        if userId then
            table.insert(playersUsingScript, userId)
        end
    end
end

-- Función para manejar el personaje del jugador local
local function onLocalCharacterAdded()
    local character = localPlayer.Character or localPlayer.CharacterAdded:Wait()
    registerLocalPlayer()
    detectScriptUsers()
    updateDisplayName(localPlayer)
end

-- Actualizar DisplayName de otros jugadores al detectarlos
local function onOtherPlayerAdded(player)
    player.CharacterAdded:Connect(function()
        wait(0.5) -- Esperar a que el personaje cargue
        detectScriptUsers()
        updateDisplayName(player)
    end)
end

-- Inicializar para el jugador local
onLocalCharacterAdded()
localPlayer.CharacterAdded:Connect(onLocalCharacterAdded)

-- Detectar otros jugadores en el servidor
game.Players.PlayerAdded:Connect(onOtherPlayerAdded)

-- Monitorear cambios en la carpeta de ScriptUsers
scriptUsersFolder.ChildAdded:Connect(function()
    detectScriptUsers()
    for _, player in pairs(game.Players:GetPlayers()) do
        updateDisplayName(player)
    end
end)

scriptUsersFolder.ChildRemoved:Connect(function()
    detectScriptUsers()
    for _, player in pairs(game.Players:GetPlayers()) do
        updateDisplayName(player)
    end
end)

-- Actualizar nombres periódicamente
while true do
    detectScriptUsers()
    for _, player in pairs(game.Players:GetPlayers()) do
        updateDisplayName(player)
    end
    wait(2)
end
